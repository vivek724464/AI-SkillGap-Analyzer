{
  "name": "ai-skill-analyzer-backend",
  "version": "1.0.0",
  "description": "Microservices backend for AI Skill Gap Analyzer",
  "main": "api-gateway/server.js",
  "type": "module",
  "scripts": {
    "start": "node api-gateway/server.js",
    "start:gateway": "node api-gateway/server.js",
    "start:auth": "node services/auth-service/server.js",
    "start:roadmap": "node services/RoadmapGenerator/server.js",
    
    "dev": "nodemon api-gateway/server.js",
    "dev:gateway": "nodemon api-gateway/server.js",
    "dev:auth": "nodemon services/auth-service/server.js",
    "dev:roadmap": "nodemon services/RoadmapGenerator/server.js",
    "check": "node --check api-gateway/server.js && node --check services/auth-service/server.js && node --check services/resume-service/server.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "multer": "^2.1.1",
    "multer-s3": "^3.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.22.0"
  }
}
